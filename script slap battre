-- GAME LOOP
RunService.Heartbeat:Connect(function()
    pcall(function()
        local char=LocalPlayer.Character if not char then return end
        local hrp=char:FindFirstChild("HumanoidRootPart") local hum=char:FindFirstChildOfClass("Humanoid")
        if States.Fly and hrp then
            local dir=Vector3.new(0,0,0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir=dir+Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir=dir-Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir=dir-Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir=dir+Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir=dir+Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir=dir-Vector3.new(0,1,0) end
            hrp.Velocity=dir.Magnitude>0 and dir.Unit*FlySpeed or Vector3.new(0,0,0)
            if hum then hum.PlatformStand=true end
        elseif hum then hum.PlatformStand=false end
        if States.Noclip then for _,p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end end
        if States.GodMode and hum then hum.MaxHealth=math.huge hum.Health=math.huge end
        if States.AntiKnockback and hrp then hrp.Velocity=Vector3.new(hrp.Velocity.X*0.05,hrp.Velocity.Y,hrp.Velocity.Z*0.05) end
        if States.AntiFall and hrp and hrp.Position.Y<-100 then local sp=workspace:FindFirstChild("SpawnLocation") hrp.CFrame=sp and sp.CFrame+Vector3.new(0,5,0) or CFrame.new(0,10,0) end
        if States.SpinBot and hrp then hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad(9),0) end
        if States.HitboxExpander and hrp then hrp.Size=Vector3.new(9,9,9) elseif hrp and hrp.Size.X>2.1 then hrp.Size=Vector3.new(2,2,1) end
        if (States.KillAura or States.AutoSlap or States.TriggerBot) and hrp then
            for _,p in ipairs(Players:GetPlayers()) do if p~=LocalPlayer and p.Character then local eh=p.Character:FindFirstChild("HumanoidRootPart") local em=p.Character:FindFirstChildOfClass("Humanoid") if eh and em and (hrp.Position-eh.Position).Magnitude<=Reach then if States.OneHitKill then em.Health=0 else em:TakeDamage(8) end end end end
        end
        if States.ESP then
            for _,p in ipairs(Players:GetPlayers()) do if p~=LocalPlayer and p.Character and not p.Character:FindFirstChild("_AdminESP") then local h=Instance.new("Highlight") h.Name="_AdminESP" h.FillColor=Color3.fromRGB(255,30,30) h.OutlineColor=Color3.white h.FillTransparency=0.45 h.Parent=p.Character end end
        else for _,p in ipairs(Players:GetPlayers()) do if p.Character then local h=p.Character:FindFirstChild("_AdminESP") if h then h:Destroy() end end end end
        if States.Tracer then
            for _,p in ipairs(Players:GetPlayers()) do if p~=LocalPlayer and p.Character then local eh=p.Character:FindFirstChild("HumanoidRootPart") if eh and hrp then local line=workspace:FindFirstChild("_Tracer_"..p.Name) if not line then line=Instance.new("Part") line.Name="_Tracer_"..p.Name line.Anchored=true line.CanCollide=false line.CastShadow=false line.Material=Enum.Material.Neon line.Color=Color3.fromRGB(255,50,50) line.Parent=workspace end local d=(eh.Position-hrp.Position).Magnitude line.Size=Vector3.new(0.05,0.05,d) line.CFrame=CFrame.new(hrp.Position,eh.Position)*CFrame.new(0,0,-d/2) end end end
        else for _,o in ipairs(workspace:GetChildren()) do if o.Name:sub(1,8)=="_Tracer_" then o:Destroy() end end end
    end)
end)

