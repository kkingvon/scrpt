local function createTab(name,icon)
    local btn=Instance.new("TextButton") btn.Size=UDim2.new(0,58,1,0) btn.BackgroundColor3=Color3.fromRGB(28,28,38) btn.Text=icon.."\n"..name btn.TextColor3=Color3.fromRGB(160,160,175) btn.TextSize=10 btn.Font=Enum.Font.GothamBold btn.BorderSizePixel=0 btn.Parent=TabBar Instance.new("UICorner",btn).CornerRadius=UDim.new(0,7)
    local page=Instance.new("ScrollingFrame") page.Size=UDim2.new(1,0,1,0) page.BackgroundTransparency=1 page.ScrollBarThickness=3 page.ScrollBarImageColor3=Color3.fromRGB(90,90,220) page.CanvasSize=UDim2.new(0,0,0,0) page.Visible=false page.Parent=ContentArea
    local layout=Instance.new("UIListLayout") layout.Padding=UDim.new(0,6) layout.Parent=page
    -- FIX: met à jour la taille du canvas automatiquement
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+12)
    end)
    Pages[name]={btn=btn,page=page}
    return page
end

local function switchTab(name)
    for n,data in pairs(Pages) do data.page.Visible=false data.btn.BackgroundColor3=Color3.fromRGB(28,28,38) data.btn.TextColor3=Color3.fromRGB(160,160,175) end
    Pages[name].page.Visible=true Pages[name].btn.BackgroundColor3=Color3.fromRGB(70,70,200) Pages[name].btn.TextColor3=Color3.white
end

