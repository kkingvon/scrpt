local function createToggle(parent,label,stateKey,callback)
    local frame=Instance.new("Frame") frame.Size=UDim2.new(1,0,0,42) frame.BackgroundColor3=Color3.fromRGB(20,20,30) frame.BorderSizePixel=0 frame.Parent=parent Instance.new("UICorner",frame).CornerRadius=UDim.new(0,9)
