    local on0=stateKey and States[stateKey] or false
    local tb=Instance.new("TextButton") tb.Size=UDim2.new(0,52,0,26) tb.Position=UDim2.new(1,-66,0.5,-13) tb.BackgroundColor3=on0 and Color3.fromRGB(45,195,95) or Color3.fromRGB(55,55,68) tb.Text=on0 and "ON" or "OFF" tb.TextColor3=on0 and Color3.white or Color3.fromRGB(160,160,170) tb.TextSize=11 tb.Font=Enum.Font.GothamBold tb.BorderSizePixel=0 tb.Parent=frame Instance.new("UICorner",tb).CornerRadius=UDim.new(1,0)
    tb.MouseButton1Click:Connect(function()
        if stateKey then States[stateKey]=not States[stateKey] local on=States[stateKey] saveConfig(stateKey,on) TweenService:Create(tb,TweenInfo.new(0.15),{BackgroundColor3=on and Color3.fromRGB(45,195,95) or Color3.fromRGB(55,55,68),TextColor3=on and Color3.white or Color3.fromRGB(160,160,170)}):Play() tb.Text=on and "ON" or "OFF" if callback then pcall(callback,on) end end
    end)
end

local function createSlider(parent,label,mn,mx,def,callback)
    local frame=Instance.new("Frame") frame.Size=UDim2.new(1,0,0,58) frame.BackgroundColor3=Color3.fromRGB(20,20,30) frame.BorderSizePixel=0 frame.Parent=parent Instance.new("UICorner",frame).CornerRadius=UDim.new(0,9)
    local vl=Instance.new("TextLabel") vl.Size=UDim2.new(1,-14,0,22) vl.Position=UDim2.new(0,14,0,6) vl.BackgroundTransparency=1 vl.Text=label..":  "..def vl.TextColor3=Color3.fromRGB(215,215,225) vl.TextSize=13 vl.Font=Enum.Font.Gotham vl.TextXAlignment=Enum.TextXAlignment.Left vl.Parent=frame
    local track=Instance.new("Frame") track.Size=UDim2.new(1,-28,0,7) track.Position=UDim2.new(0,14,0,38) track.BackgroundColor3=Color3.fromRGB(45,45,60) track.BorderSizePixel=0 track.Parent=frame Instance.new("UICorner",track).CornerRadius=UDim.new(0,4)
    local fill=Instance.new("Frame") fill.Size=UDim2.new((def-mn)/(mx-mn),0,1,0) fill.BackgroundColor3=Color3.fromRGB(75,75,210) fill.BorderSizePixel=0 fill.Parent=track Instance.new("UICorner",fill).CornerRadius=UDim.new(0,4)
    local drag=false
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then local rel=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1) local val=math.floor(mn+rel*(mx-mn)) fill.Size=UDim2.new(rel,0,1,0) vl.Text=label..":  "..val if callback then pcall(callback,val) end end
    end)
end

local function createButton(parent,label,color,callback)
    local c=color or Color3.fromRGB(70,70,200)
    local btn=Instance.new("TextButton") btn.Size=UDim2.new(1,0,0,38) btn.BackgroundColor3=c btn.Text=label btn.TextColor3=Color3.white btn.TextSize=13 btn.Font=Enum.Font.GothamBold btn.BorderSizePixel=0 btn.Parent=parent Instance.new("UICorner",btn).CornerRadius=UDim.new(0,9)
    btn.MouseButton1Click:Connect(function()
        TweenService:Create(btn,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(math.min(c.R*255+40,255),math.min(c.G*255+40,255),math.min(c.B*255+40,255))}):Play()
        task.delay(0.15,function() TweenService:Create(btn,TweenInfo.new(0.1),{BackgroundColor3=c}):Play() end)
        if callback then pcall(callback) end
    end)
    return btn
end

